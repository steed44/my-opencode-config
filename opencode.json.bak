{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    },
    "headroom": {
      "type": "local",
      "command": [
        "C:\\Users\\ght\\AppData\\Roaming\\Python\\Python314\\Scripts\\headroom.exe",
        "mcp",
        "serve"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-session-renamer",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./plugins/caveman/plugin.js"
  ],
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      }
    },
    "claude-code": {
      "npm": "opencode-claude-client",
      "name": "Claude Code CLI",
      "options": {}
    }
  },
  "instructions": [
    "AGENTS.md",
    "graphify-out/GRAPH_REPORT.md"
  ]
}




